# Ignore compiled or temporary files
backend/dist/
backend/tmp/
backend/uploads/

# -------------------------------
# 🤖 ML SERVICE (Python + Deep Learning)
# -------------------------------
ml_service/__pycache__/
ml_service/.env
ml_service/.DS_Store
ml_service/*.pyc
ml_service/venv/
ml_service/.venv/
ml_service/.ipynb_checkpoints/

# Model files (large binaries)
ml_service/model/*.h5
ml_service/model/*.pt
ml_service/model/*.pkl
ml_service/model/*.joblib

